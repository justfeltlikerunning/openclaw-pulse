[Unit]
Description=agent-pulse Slack Bridge
Documentation=https://github.com/your-org/agent-pulse
After=network.target agent-pulse-hub.service
Requires=agent-pulse-hub.service

[Service]
Type=simple
User=%i
WorkingDirectory=/opt/agent-pulse

# The bridge uses native fetch() from Node 22 - no extra npm deps needed.
ExecStart=/usr/bin/node src/slack-bridge.js

Restart=on-failure
RestartSec=5s
StandardOutput=journal
StandardError=journal

# Environment - set these in a drop-in or EnvironmentFile.
# Create /etc/agent-pulse/slack-bridge.env with:
#   SLACK_TOKEN=xoxb-your-token-here
#   SLACK_CHANNEL=YOUR_CHANNEL_ID
#   PULSE_API_URL=http://127.0.0.1:18801
EnvironmentFile=-/etc/agent-pulse/slack-bridge.env

# Security hardening.
NoNewPrivileges=yes
PrivateTmp=yes
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=/opt/agent-pulse/state /opt/agent-pulse/logs

[Install]
WantedBy=multi-user.target
